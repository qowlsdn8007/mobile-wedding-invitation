{
  "rules": {
    ".read": false,
    ".write": false,

    "likes": {
      ".read": true,
      ".write": "newData.isNumber() && ((!data.exists() && newData.val() === 1) || newData.val() === data.val() + 1)"
    },

    "guestbook": {
      ".read": true,
      "$entry": {
        ".write": "!data.exists() && newData.exists()",
        ".validate": "newData.hasChildren(['sender', 'message', 'createdAt', 'date'])",
        "sender": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 20"
        },
        "message": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 500"
        },
        "createdAt": {
          ".validate": "newData.val() === now"
        },
        "date": {
          ".validate": "newData.isString() && newData.val().length <= 40"
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
